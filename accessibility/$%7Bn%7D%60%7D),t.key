op:12px;}.css-edbmnk p,.css-edbmnk span{opacity:0.8;font-weight:400;text-align:inherit!important;font-size:13px!important;margin-bottom:0!important;line-height:136%!important;}@media (min-width: 413px){.css-edbmnk{margin-top:24px;}.css-edbmnk p,.css-edbmnk span{font-size:16px!important;}}@media (min-width: 901px){.css-edbmnk p,.css-edbmnk span{font-size:20px!important;line-height:128%!important;}}</style><div class="css-edbmnk"><p style="text-align: left;line-height: 1.5;margin: 0px 0px 32px;">TikTok is a place for all. We’re committed to creating an inclusive space where everyone can express themselves. That’s why we’re building accessibility tools and improving experiences for people with disabilities — as part of our ongoing efforts to meet Web Content Accessibility Guidelines (WCAG) 2.2 AA.</p></div></div><style data-emotion="css ulj3uy">.css-ulj3uy{aspect-ratio:5/4;object-fit:contain;}@media (min-width: 901px){.css-ulj3uy{height:26vw;max-height:42rem;min-height:28rem;}}</style><img alt="accessibility hero" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/44080c6317e4a7e6e990ceb56cbf6ff2.png~tplv-1rzkm2vceq-default:0:0:q75.image" class="css-ulj3uy"/></div></div><style data-emotion="css 1v3dic5">.css-1v3dic5{padding:0 24px;margin:48px auto 0 auto;display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;justify-items:center;-webkit-box-pack:center;-ms-flex-pack:center;-webkit-justify-content:center;justify-content:center;-webkit-align-items:center;-webkit-box-align:center;-ms-flex-align:center;align-items:center;text-align:center;}@media (min-width: 901px){.css-1v3dic5{margin-top:80px;}}@media (min-width: 1201px){.css-1v3dic5{padding:0 80px;}}</style><div class="css-1v3dic5"><style data-emotion="css lre59p">.css-lre59p{box-sizing:border-box;width:100%;height:100%;}@media (min-width: 901px){.css-lre59p{max-width:1568px;}}</style><div class="css-lre59p"><style data-emotion="css 1d0gqtm">.css-1d0gqtm{height:100%;width:100%;font-weight:700;}@media (min-width: 901px){.css-1d0gqtm h2{font-size:4.8rem;line-height:5.52rem;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-1d0gqtm h2{font-size:3.2rem;line-height:3.84rem;}}</style><div class="css-1d0gqtm"><h2>Accessibility feature highlights</h2></div><style data-emotion="css 15ce7ht">.css-15ce7ht{width:100%;font-weight:400;margin-top:40px;}.css-15ce7ht .feature-light:not(:first-of-type){margin-top:40px;}@media (min-width: 901px){.css-15ce7ht{margin-top:64px;}.css-15ce7ht .feature-light:not(:first-of-type){margin-top:120px;}}</style><div class="css-15ce7ht"><style data-emotion="css f4bdkq">.css-f4bdkq{width:100%;font-weight:400;}@media (min-width: 901px){.css-f4bdkq{display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-box-pack:justify;-webkit-justify-content:space-between;justify-content:space-between;-webkit-align-items:center;-webkit-box-align:center;-ms-flex-align:center;align-items:center;-webkit-flex-direction:row-reverse;-ms-flex-direction:row-reverse;flex-direction:row-reverse;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-f4bdkq{display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-align-items:center;-webkit-box-align:center;-ms-flex-align:center;align-items:center;}}</style><div class="feature-light css-f4bdkq"><style data-emotion="css 1boe9pv">.css-1boe9pv{text-align:left;width:100%;}html[dir='rtl'] .css-1boe9pv{text-align:right;}@media (min-width: 901px){.css-1boe9pv{padding-inline:60px 10px;-webkit-flex:1;-ms-flex:1;flex:1;}.css-1boe9pv p{margin-top:16px;line-height:2.52rem;font-size:1.8rem;}.css-1boe9pv h3{font-size:3.2rem;line-height:3.84rem;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-1boe9pv p,.css-1boe9pv a{line-height:2.08rem;font-size:1.6rem;}.css-1boe9pv p{margin-top:16px;}.css-1boe9pv h3{font-size:2.4rem;line-height:2.88rem;}}</style><div class="css-1boe9pv"><div><h3 level="3" id="" align="">Add <span style="color: #00979D;">alternative text</span> to your TikTok photo posts</h3></div><div><p>Adding descriptive alt text to your photo posts can help those with visual impairments understand the content of your photos and have a more inclusive TikTok experience.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Accessibility</strong>.</p></div><a href="https://support.tiktok.com/en/using-tiktok/creating-videos/accessibility#1" target="_blank" rel="noreferrer">Learn more about alternative text<!-- --> <style data-emotion="css 1o0j6ez">.css-1o0j6ez{display:inline-block;vertical-align:middle;}</style><span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><style data-emotion="css 18ous5h">.css-18ous5h{-webkit-flex:1;-ms-flex:1;flex:1;}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-18ous5h{margin-top:24px;}}.css-18ous5h img{border-radius:32px;}</style><div class="css-18ous5h"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/80af0e49777c7c1169074efef8362f9b.png~tplv-1rzkm2vceq-default:0:0:q75.image" width="100%"/></div></div><style data-emotion="css 1czo5f6">.css-1czo5f6{width:100%;font-weight:400;}@media (min-width: 901px){.css-1czo5f6{display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-box-pack:justify;-webkit-justify-content:space-between;justify-content:space-between;-webkit-align-items:center;-webkit-box-align:center;-ms-flex-align:center;align-items:center;-webkit-flex-direction:row;-ms-flex-direction:row;flex-direction:row;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-1czo5f6{display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-align-items:center;-webkit-box-align:center;-ms-flex-align:center;align-items:center;}}</style><div class="feature-light css-1czo5f6"><style data-emotion="css 1526lvg">.css-1526lvg{text-align:left;width:100%;}html[dir='rtl'] .css-1526lvg{text-align:right;}@media (min-width: 901px){.css-1526lvg{padding-inline:10px 60px;-webkit-flex:1;-ms-flex:1;flex:1;}.css-1526lvg p{margin-top:16px;line-height:2.52rem;font-size:1.8rem;}.css-1526lvg h3{font-size:3.2rem;line-height:3.84rem;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-1526lvg p,.css-1526lvg a{line-height:2.08rem;font-size:1.6rem;}.css-1526lvg p{margin-top:16px;}.css-1526lvg h3{font-size:2.4rem;line-height:2.88rem;}}</style><div class="css-1526lvg"><div><h3 level="3" id="" align="">Use a <span style="color: #DA5CCE;">screen reader</span> for TikTok</h3></div><div><p>TikTok's "feed navigation buttons" enhances navigation on the "For You" feed, allowing you to pause, play, and move between videos with ease. This tool is activated when Talkback (Android) or VoiceOver (iOS) screen readers are enabled.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Accessibility</strong>.</p></div><a href="https://support.tiktok.com/en/using-tiktok/exploring-videos/accessibility-for-watching-videos#5" target="_blank" rel="noreferrer">Learn more about feed navigation buttons<!-- --> <span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><div class="css-18ous5h"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/e758859b855f75a8079a845999a82087.png~tplv-1rzkm2vceq-default:0:0:q75.image" width="100%"/></div></div><div class="feature-light css-f4bdkq"><div class="css-1boe9pv"><div><h3 level="3" id="" align="">Adjust <span style="color: #C87300;">text size</span> on TikTok</h3></div><div><p>Change the text size in the app to make it easier to read and better suited to your preferences.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Accessibility</strong>.</p></div><a href="https://support.tiktok.com/en/using-tiktok/exploring-videos/accessibility-for-watching-videos#7" target="_blank" rel="noreferrer">Learn how to adjust text size<!-- --> <span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><div class="css-18ous5h"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/e0e7a63ec0bda1756d782e50adec4047.png~tplv-1rzkm2vceq-default:0:0:q75.image" width="100%"/></div></div><div class="feature-light css-1czo5f6"><div class="css-1526lvg"><div><h3 level="3" id="" align="">Turn on <span style="color: #009963;">standard video playback</span></h3></div><div><p>High Dynamic Range (HDR) videos can sometimes appear excessively bright or sharp. Turning on standard video playback automatically adjusts these videos to standard dynamic range (SDR), helping those who may be sensitive to intense light or high contrast.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Playback</strong> for iOS, or <strong>Settings and privacy &gt; Accessibility</strong> for Android.</p></div><a href="https://www.tiktok.com/support/faq_detail?category=web_posts&amp;id=7581820706338642443#8" target="_blank" rel="noreferrer">Learn more about standard video playback<!-- --> <span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><div class="css-18ous5h"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/93ee4f10ef1a30ab35104d23ec6d1718.png~tplv-1rzkm2vceq-default:0:0:q75.image" width="100%"/></div></div><div class="feature-light css-f4bdkq"><div class="css-1boe9pv"><div><h3 level="3" id="" align="">Turn "<span style="color: #920909;">Dark mode</span>" on or off</h3></div><div><p>Turning on dark mode will give the app a dark background with light text. Dark mode provides a visually appealing and potentially eye-friendly alternative to the standard light theme. By reducing screen brightness and contrast, dark mode can help reduce eye strain, especially in low-light environments. Dark mode doesn't change the way videos look on TikTok.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Display.</strong></p></div><a href="https://support.tiktok.com/en/account-and-privacy/account-privacy-settings/dark-mode" target="_blank" rel="noreferrer">Learn more about dark mode<!-- --> <span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><div class="css-18ous5h"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/6c1d2fc97bcfa84cd117916c745f95c1.png~tplv-1rzkm2vceq-default:0:0:q75.image" width="100%"/></div></div><div class="feature-light css-1czo5f6"><div class="css-1526lvg"><div><h3 level="3" id="" align="">Manage <span style="color: #8470FF;">auto-generated captions</span> on your TikTok videos</h3></div><div><p>Auto captions automatically generate subtitles, allowing viewers to read or listen to content.</p><p><strong>For Creators:</strong> Creators can add captions during video editing. The text is transcribed automatically and can be edited before being displayed.</p><p><strong>For Viewers:</strong> Viewers can choose to show or hide auto-generated captions while watching videos.</p><p>This feature can be managed from long-press on the video you're watching and tap <strong>Captions</strong>.</p></div><a href="https://newsroom.tiktok.com/en-us/introducing-auto-captions" target="_blank" rel="noreferrer">Learn more about auto-generated captions<!-- --> <span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><div class="css-18ous5h"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/7146f6391e3f5e79a90917a99511a80f.png~tplv-1rzkm2vceq-default:0:0:q75.image" width="100%"/></div></div><div class="feature-light css-f4bdkq"><div class="css-1boe9pv"><div><h3 level="3" id="" align=""><span style="color: #009963;">Remove photosensitive</span> videos</h3></div><div><p>For people with photosensitive epilepsy, you can remove videos that may trigger seizures or migraines. A warning will also appear in your feed to help you avoid content that could cause discomfort.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Accessibility.</strong></p></div><a href="https://newsroom.tiktok.com/en-us/making-tiktok-more-accessible-to-people-with-photosensitive-epilepsy" target="_blank" rel="noreferrer">Learn how to remove photosensitive videos<!-- --> <span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><div class="css-18ous5h"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/45c6a188142790af5ba096b6dab45c0b.png~tplv-1rzkm2vceq-default:0:0:q75.image" width="100%"/></div></div></div></div></div><style data-emotion="css hpiw2r">.css-hpiw2r{display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;justify-items:center;-webkit-box-pack:center;-ms-flex-pack:center;-webkit-justify-content:center;justify-content:center;-webkit-align-items:center;-webkit-box-align:center;-ms-flex-align:center;align-items:center;text-align:center;margin:48px auto 0 auto;padding:0 24px;}@media (min-width: 901px){.css-hpiw2r{margin-top:80px;}}@media (min-width: 1201px){.css-hpiw2r{padding:0 80px;}}</style><div class="css-hpiw2r"><style data-emotion="css 1ioa2c8">.css-1ioa2c8{box-sizing:border-box;height:100%;}@media (min-width: 901px){.css-1ioa2c8{max-width:1568px;}}</style><div class="css-1ioa2c8"><style data-emotion="css rpkkaq">.css-rpkkaq{height:100%;width:100%;font-weight:700;}@media (min-width: 901px){.css-rpkkaq h2{font-size:4.8rem;line-height:5.52rem;}}</style><div class="css-rpkkaq"><h2>Other accessibility features</h2></div><style data-emotion="css j8fjc0">.css-j8fjc0{--gap:32px;--columns:1;width:100%;font-weight:400;margin-top:40px;display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-box-flex-wrap:wrap;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:var(--gap);}@media (min-width: 901px){.css-j8fjc0{--columns:3;}}@media (min-width: 901px){.css-j8fjc0{margin-top:64px;}}</style><div class="css-j8fjc0"><style data-emotion="css 1cin8gc">.css-1cin8gc{border-radius:32px;margin:0 0 0 0;padding:32px;background-color:#f5f5f5;color:#181818;text-align:left;}html[dir='rtl'] .css-1cin8gc{text-align:right;}.css-1cin8gc h3{color:#F1204A;}@media (min-width: 901px){.css-1cin8gc{width:calc((100% / var(--columns)) - var(--gap) + (var(--gap) / var(--columns)));}.css-1cin8gc h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-1cin8gc p{line-height:25.2px;margin:12px 0 0 0;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-1cin8gc{height:auto;}.css-1cin8gc h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-1cin8gc p,.css-1cin8gc a{line-height:2.08rem;font-size:1.6rem;}.css-1cin8gc p{line-height:25.2px;margin:12px 0 0 0;}}</style><div class="other-feature css-1cin8gc"><style data-emotion="css 1rn3dkw">.css-1rn3dkw{width:48px;height:48px;}@media (min-width: 901px){.css-1rn3dkw{width:56px;height:56px;}}</style><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/099b7330e54341627af201e8e8204873.png~tplv-1rzkm2vceq-default:0:0:q75.image" class="css-1rn3dkw"/><h3>Reduced motion</h3><div><p>The reduced motion feature allows you to minimize screen transitions across the app. This creates a more static interface that is easier on the eyes and better suited to those who are sensitive to fast-moving visual effects.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Accessibility</strong>.</p></div><style data-emotion="css rjxg76">.css-rjxg76{display:inline-block;margin-top:12px;white-space:break-spaces;}</style><a href="https://www.tiktok.com/support/faq_detail?category=web_posts&amp;id=7581820706338642443#7" target="_blank" rel="noreferrer" class="css-rjxg76">Learn more about reduced motion<!-- --> <style data-emotion="css 1o0j6ez">.css-1o0j6ez{display:inline-block;vertical-align:middle;}</style><span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><style data-emotion="css 1uuygd6">.css-1uuygd6{border-radius:32px;margin:0 0 0 0;padding:32px;background-color:#f5f5f5;color:#181818;text-align:left;}html[dir='rtl'] .css-1uuygd6{text-align:right;}.css-1uuygd6 h3{color:#00979D;}@media (min-width: 901px){.css-1uuygd6{width:calc((100% / var(--columns)) - var(--gap) + (var(--gap) / var(--columns)));}.css-1uuygd6 h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-1uuygd6 p{line-height:25.2px;margin:12px 0 0 0;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-1uuygd6{height:auto;}.css-1uuygd6 h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-1uuygd6 p,.css-1uuygd6 a{line-height:2.08rem;font-size:1.6rem;}.css-1uuygd6 p{line-height:25.2px;margin:12px 0 0 0;}}</style><div class="other-feature css-1uuygd6"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/c57d0d23eadf8446a698ac1fdcc2c65e.png~tplv-1rzkm2vceq-default:0:0:q75.image" class="css-1rn3dkw"/><h3>Change playback speed</h3><div><p>Watch videos at your own pace by changing PlayBack Speed. Whether you need to slow down to catch details or speed up to save time, this feature provides flexibility.</p><p>This feature can be managed by long-press on the video you're watching and tap <strong>Playback Speed</strong>.</p></div></div><style data-emotion="css 53l8p4">.css-53l8p4{border-radius:32px;margin:0 0 0 0;padding:32px;background-color:#f5f5f5;color:#181818;text-align:left;}html[dir='rtl'] .css-53l8p4{text-align:right;}.css-53l8p4 h3{color:#DA5CCE;}@media (min-width: 901px){.css-53l8p4{width:calc((100% / var(--columns)) - var(--gap) + (var(--gap) / var(--columns)));}.css-53l8p4 h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-53l8p4 p{line-height:25.2px;margin:12px 0 0 0;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-53l8p4{height:auto;}.css-53l8p4 h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-53l8p4 p,.css-53l8p4 a{line-height:2.08rem;font-size:1.6rem;}.css-53l8p4 p{line-height:25.2px;margin:12px 0 0 0;}}</style><div class="other-feature css-53l8p4"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/876694c598ccfc3385a340236b91059c.png~tplv-1rzkm2vceq-default:0:0:q75.image" class="css-1rn3dkw"/><h3>Text-to-speech</h3><div><p>Text-to-speech converts typed text to a voiceover that plays over the text as it appears in the video. This feature is particularly helpful for visually impaired or blind users.</p></div><a href="https://support.tiktok.com/en/using-tiktok/creating-videos/accessibility#5" target="_blank" rel="noreferrer" class="css-rjxg76">Learn more about text-to-speech<!-- --> <span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><style data-emotion="css 11hyesz">.css-11hyesz{border-radius:32px;margin:0 0 0 0;padding:32px;background-color:#f5f5f5;color:#181818;text-align:left;}html[dir='rtl'] .css-11hyesz{text-align:right;}.css-11hyesz h3{color:#C87300;}@media (min-width: 901px){.css-11hyesz{width:calc((100% / var(--columns)) - var(--gap) + (var(--gap) / var(--columns)));}.css-11hyesz h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-11hyesz p{line-height:25.2px;margin:12px 0 0 0;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-11hyesz{height:auto;}.css-11hyesz h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-11hyesz p,.css-11hyesz a{line-height:2.08rem;font-size:1.6rem;}.css-11hyesz p{line-height:25.2px;margin:12px 0 0 0;}}</style><div class="other-feature css-11hyesz"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/0d1287952d9322c38c127709f0b0d37d.png~tplv-1rzkm2vceq-default:0:0:q75.image" class="css-1rn3dkw"/><h3>Bold text</h3><div><p>If your device's bold text setting is turned on, text in the TikTok app will automatically appear bolder to improve readability. To manage bold text in the TikTok app, you'll have to go to your device's display settings and turn the setting on or off.</p><p>To learn more about your device's bold text setting, visit <a href="https://support.apple.com/" target="_blank" rel="nofollow noreferrer" class="syl-link" data-href-mobile="" data-entry-id="" data-anchor-id="">Apple Support</a> or <a href="https://support.google.com/accessibility" target="_blank" rel="nofollow noreferrer" class="syl-link" data-href-mobile="" data-entry-id="" data-anchor-id="">Android Accessibility Help</a>.</p></div></div><style data-emotion="css 10zzqz5">.css-10zzqz5{border-radius:32px;margin:0 0 0 0;padding:32px;background-color:#f5f5f5;color:#181818;text-align:left;}html[dir='rtl'] .css-10zzqz5{text-align:right;}.css-10zzqz5 h3{color:#920909;}@media (min-width: 901px){.css-10zzqz5{width:calc((100% / var(--columns)) - var(--gap) + (var(--gap) / var(--columns)));}.css-10zzqz5 h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-10zzqz5 p{line-height:25.2px;margin:12px 0 0 0;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-10zzqz5{height:auto;}.css-10zzqz5 h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-10zzqz5 p,.css-10zzqz5 a{line-height:2.08rem;font-size:1.6rem;}.css-10zzqz5 p{line-height:25.2px;margin:12px 0 0 0;}}</style><div class="other-feature css-10zzqz5"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/f751dc2fe166cd2c7c9d8faff3e0e07b.png~tplv-1rzkm2vceq-default:0:0:q75.image" class="css-1rn3dkw"/><h3>Change scroll speed</h3><div><p>The Change Scroll Speed feature allows you to double your scrolling speed, making it easier to quickly discover new content.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Accessibility</strong>.</p></div></div><style data-emotion="css 1ce0on9">.css-1ce0on9{border-radius:32px;margin:0 0 0 0;padding:32px;background-color:#f5f5f5;color:#181818;text-align:left;}html[dir='rtl'] .css-1ce0on9{text-align:right;}.css-1ce0on9 h3{color:#8470FF;}@media (min-width: 901px){.css-1ce0on9{width:calc((100% / var(--columns)) - var(--gap) + (var(--gap) / var(--columns)));}.css-1ce0on9 h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-1ce0on9 p{line-height:25.2px;margin:12px 0 0 0;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-1ce0on9{height:auto;}.css-1ce0on9 h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-1ce0on9 p,.css-1ce0on9 a{line-height:2.08rem;font-size:1.6rem;}.css-1ce0on9 p{line-height:25.2px;margin:12px 0 0 0;}}</style><div class="other-feature css-1ce0on9"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/31d5a784a511ca37e776f05497a03ed6.png~tplv-1rzkm2vceq-default:0:0:q75.image" class="css-1rn3dkw"/><h3>Thumbnail animation</h3><div><p>TikTok offers you the flexibility to choose between animated or static thumbnails for your videos. This option allows you to customize your viewing experience based on your preferences or visual comfort.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Accessibility</strong>.</p></div><a href="https://support.tiktok.com/en/using-tiktok/exploring-videos/accessibility-for-watching-videos#1" target="_blank" rel="noreferrer" class="css-rjxg76">Learn more about animated thumbnail<!-- --> <span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div><style data-emotion="css joz9kw">.css-joz9kw{border-radius:32px;margin:0 0 0 0;padding:32px;background-color:#f5f5f5;color:#181818;text-align:left;}html[dir='rtl'] .css-joz9kw{text-align:right;}.css-joz9kw h3{color:#009963;}@media (min-width: 901px){.css-joz9kw{width:calc((100% / var(--columns)) - var(--gap) + (var(--gap) / var(--columns)));}.css-joz9kw h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-joz9kw p{line-height:25.2px;margin:12px 0 0 0;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-joz9kw{height:auto;}.css-joz9kw h3{font-size:2.4rem;line-height:3rem;margin:24px 0 4px 0;}.css-joz9kw p,.css-joz9kw a{line-height:2.08rem;font-size:1.6rem;}.css-joz9kw p{line-height:25.2px;margin:12px 0 0 0;}}</style><div class="other-feature css-joz9kw"><img alt="" src="https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/6907ed91e536d307b4af20465fa150a1.png~tplv-1rzkm2vceq-default:0:0:q75.image" class="css-1rn3dkw"/><h3>Control color contrast</h3><div><p>By increasing the color contrast on the app, you can view a more comfortable display and reduce eye strain. This tool can be helpful for those with visual impairments, or for those viewing TikTok in bright, outdoor settings.</p><p>This feature can be managed from <strong>Settings and privacy &gt; Accessibility.</strong></p></div><a href="https://support.tiktok.com/en/using-tiktok/exploring-videos/accessibility-for-watching-videos#3" target="_blank" rel="noreferrer" class="css-rjxg76">Learn how to control color contrast<!-- --> <span aria-hidden="true" class="css-1o0j6ez"><svg fill="currentColor" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" class="flip-rtl "><path d="M38.91 6.1H17.3a1 1 0 0 0-1 1v3.98a1 1 0 0 0 1.01 1l14.62-.24L7.1 36.67a1 1 0 0 0 0 1.41l2.83 2.83a1 1 0 0 0 1.42 0l24.82-24.83-.23 14.62a1 1 0 0 0 1 1.02h3.98a1 1 0 0 0 1-1V9.09a3 3 0 0 0-3-3Z"></path></svg></span></a></div></div></div></div><style data-emotion="css 1rh8i5z">.css-1rh8i5z{width:100%;margin-top:126px;display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-box-pack:center;-ms-flex-pack:center;-webkit-justify-content:center;justify-content:center;-webkit-align-items:center;-webkit-box-align:center;-ms-flex-align:center;align-items:center;padding:56px 0;text-align:center;}@media (min-width: 901px){.css-1rh8i5z{background-image:url(https://p16-ttark.tiktokcdn-us.com/tos-useast5-i-1rzkm2vceq-tx/8a7bdba08386e262d6d3803e5457919e.jpg~tplv-1rzkm2vceq-default:0:0:q75.image);-webkit-background-size:cover;background-size:cover;-webkit-background-position:center center;background-position:center center;background-repeat:no-repeat;}}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-1rh8i5z{background-color:#f5f5f5;margin-top:120px;}}</style><div class="css-1rh8i5z"><style data-emotion="css 10bgddk">.css-10bgddk{width:567px;}.css-10bgddk p{margin-bottom:0px;}.css-10bgddk h2{margin-bottom:12px;}@media (max-width: 900px),(min-width: 900px) and (max-width: 900px){.css-10bgddk h2{font-size:2.4rem;line-height:2.88rem;}.css-10bgddk p{margin:0;font-weight:400;font-size:16px!important;line-heig